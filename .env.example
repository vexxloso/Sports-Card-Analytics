# Copy to .env or use server/.env — ingest loads FIRST existing file only:
#   server/.env  then  .env  (same as Catawiki scraper; does not override shell env).

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# EBAY_ES matches default in Catawiki script; use EBAY-US for US comps.
EBAY_MARKETPLACE_ID=EBAY-US

# Sandbox app keys only: EBAY_SANDBOX=true

# Pause between search pages (seconds); Catawiki uses ~1s before each call.
# EBAY_SEARCH_THROTTLE_SEC=1

# 24/7 daemon: default is ON (run now, then every day at UTC time). Opt out: RUN_DAILY=false
# Or single run: python ingest_ebay.py --once
RUN_DAILY=true
RUN_HOUR_UTC=0
RUN_MINUTE_UTC=0

# If true, skip ingest when buy.browse app quota remaining is 0 (like Catawiki bot).
# SKIP_IF_NO_EBAY_QUOTA=false

# MongoDB connection URI (local: mongodb://localhost:27017)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=sports_cards
MONGODB_COLLECTION=ebay_items
MONGODB_CARDS_COLLECTION=cards

# MERN API (Express loads root .env from project root)
API_PORT=5000
API_LISTEN_HOST=0.0.0.0
#
# --- Typical “incomplete project” VPS: API only in dev mode ---
# On the server: npm run vps:dev   (NODE_ENV defaults to development → CORS allows any origin)
# On your PC after npm run build:web:
#   Set API_PROXY_TARGET=http://YOUR_VPS_IP:5000 then npm run preview:web
#   (Built UI uses relative /api; preview proxies it to the VPS.)
# Or run npm run dev:web with the same API_PROXY_TARGET.
#
# production NODE_ENV=production + CLIENT_ORIGIN for locked CORS (see npm run prod:vps).
CLIENT_ORIGIN=http://localhost:5173
# Where Express listens — used only by Vite dev + preview /api proxy (not embedded in the production bundle).
API_PROXY_TARGET=http://127.0.0.1:5000
# Static hosting (S3, nginx, etc.): put API URL into the bundle — add gitignored `.env.production.local`:
#   VITE_API_URL=http://YOUR_VPS_IP:5000
# then npm run build:web
# Optional absolute path when Express serves client/dist:
# WEB_DIST=/var/www/sports-card-analytics/client/dist
# Legacy: if set, Vite proxy also uses this. Prefer API_PROXY_TARGET for clarity.
# VITE_API_URL=http://127.0.0.1:5000
DASHBOARD_MOVERS_MIN_COUNT=2
DASHBOARD_MOVERS_LIMIT=20

# Optional: narrow to Sports Trading Cards (US). Leave empty to search globally.
# EBAY_CATEGORY_IDS=261328

# Search query (signed / graded / auth keywords — adjust as needed)
EBAY_SEARCH_QUERY=(autograph OR signed OR auto) (PSA OR BGS OR BVG OR JSA OR Beckett OR "PSA DNA" OR COA)

# Pagination (offset + limit per eBay Browse API; cap 200 per request)
# For ~1000 listings: EBAY_LIMIT=50 and 20 pages, or EBAY_LIMIT=200 and 5 pages.
EBAY_LIMIT=50
EBAY_MAX_ITEMS=1000

# HTTP resilience (timeouts / retries). Smaller EBAY_LIMIT can reduce timeouts on slow VPS.
# EBAY_HTTP_CONNECT_TIMEOUT_SEC=30
# EBAY_HTTP_READ_TIMEOUT_SEC=120
# EBAY_HTTP_MAX_RETRIES=5
# EBAY_HTTP_RETRY_BACKOFF_SEC=3
# EBAY_SKIP_FAILED_PAGE=true
# EBAY_MAX_CONSECUTIVE_PAGE_SKIPS=8

# If item has watchCount from API, require at least this many (0 = no filter).
# Note: many Browse responses omit watchCount; see README note in ingest output.
MIN_WATCH_COUNT=10

# If true, drop items when watchCount is missing and MIN_WATCH_COUNT > 0
STRICT_WATCH_COUNT=false
