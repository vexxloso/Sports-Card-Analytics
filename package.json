{
  "name": "sports-card-analytics",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev:api": "npm run dev --prefix server",
    "vps:dev": "npm run dev --prefix server",
    "dev:web": "npm run dev --prefix client",
    "preview:web": "npm run preview --prefix client",
    "start:api": "npm start --prefix server",
    "build:web": "npm run build --prefix client",
    "build": "npm run build:web",
    "start:prod": "cross-env NODE_ENV=production npm start --prefix server",
    "prod:vps": "npm run build:web && cross-env NODE_ENV=production npm start --prefix server"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
